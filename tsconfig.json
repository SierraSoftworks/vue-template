{
    "include": [
        "src/**/*.ts"
    ],
    "compilerOptions": {
        "target": "es2015",
        "module": "esnext",
        "moduleResolution": "bundler",
        "experimentalDecorators": true,
        "allowJs": true,
        "esModuleInterop": true,
        "lib": [
            "es2015",
            "dom"
        ],
        "rootDir": "./src",
        "noImplicitAny": false,
        "strictNullChecks": false,
        "skipLibCheck": true,
        "paths": {
            "vuex": ["./node_modules/vuex/types/index.d.ts"],
            "vuex/*": ["./node_modules/vuex/types/*"]
        }
    }
}