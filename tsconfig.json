{
    "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"],
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "types": ["vite/client"]
    }
}